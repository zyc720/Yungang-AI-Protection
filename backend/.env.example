# LLM Provider: "deepseek" or "vllm"
LLM_PROVIDER=vllm

# DeepSeek API (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# vLLM Local Deployment (used when LLM_PROVIDER=vllm)
VLLM_BASE_URL=http://localhost:8002/v1
VLLM_MODEL=casperhansen/deepseek-r1-distill-qwen-32b-awq

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=yungang_dictionary
MILVUS_COLLECTION_NAME=knowledge_chunks
USE_MILVUS_LITE=true

# BGE-M3 Embedding
BGE_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO

# Retrieval
RETRIEVAL_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
